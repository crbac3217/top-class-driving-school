---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
const year = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-300 py-10 mt-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 flex flex-col md:flex-row items-center justify-between gap-4 text-sm">
    <div>
      <span class="font-bold text-white text-base">Top Class Driving School</span>
      <p class="mt-1 text-gray-400">{tr.footer.tagline}</p>
    </div>
    <p class="text-gray-500">&copy; {year} Top Class Driving School. {tr.footer.rights}</p>
  </div>
</footer>
